---
const buku = [
  { img: '/covers/ipas-1-1.jpg',              nama: 'Anak Islam Belajar IPAS',             kelas: 'Kelas 1–6 · SD/MI' },
  { img: '/covers/mtk-1-1.jpg',        nama: 'Anak Islam Belajar Matematika',       kelas: 'Kelas 1–6 · SD/MI' },
  { img: '/covers/bind-1-1.jpg',  nama: 'Anak Islam Belajar Bahasa Indonesia', kelas: 'Kelas 1–6 · SD/MI' },
  { img: '/covers/tematik-1-1.jpg',           nama: 'Anak Islam Belajar Tematik',          kelas: 'Kelas 1–6 · SD/MI' },
];
---
<div class="section" id="buku">
  <p class="section-label">Produk Unggulan</p>
  <h2 class="section-title">Buku Pelajaran untuk Sekolah Islam</h2>
  <p class="section-desc">Sesuai Kurikulum Merdeka - CP 2025, terintegrasi nilai-nilai Islam yang mulia.<br/>
      Seri <strong>Anak Islam Belajar</strong> adalah buku kurikulum merdeka untuk sekolah Islam, SD/MI, SDIT, dan PKBM Islam.
  </p>

  <!-- SD/MI -->
  <div class="jenjang-group">
    <div class="jenjang-header open" data-toggle>
      <div>
        <div class="jenjang-title">SD, MI, SDIT, PKBM Islam</div>
        <div class="jenjang-meta">IPAS, MTK, Bahasa Indonesia · Kelas 1–6 · Semester 1 & 2</div>
      </div>
      <span class="jenjang-arrow">▲</span>
    </div>
    <div class="jenjang-body open">
      <div class="buku-list">
        {buku.map(b => (
          <div class="buku-card">
            <div class="buku-img-wrap">
              <img src={b.img} alt={b.nama} class="buku-img" loading="lazy" />
            </div>
            <div class="buku-nama">{b.nama}</div>
            <div class="buku-kelas">{b.kelas}</div>
            <div class="buku-badge">Kurikulum Merdeka</div>
          </div>
        ))}
      </div>
      <div class="jenjang-actions">
        <a href="/katalog" class="btn-katalog">📚 Lihat Katalog Lengkap</a>
        <a href="https://luqmanulhakim.net/pesanan" target="_blank" rel="noopener" class="btn-pesan">🛒 Pesan Sekarang</a>
      </div>
    </div>
  </div>

  <!-- SMP/MTs -->
  <div class="jenjang-group">
    <div class="jenjang-header" data-toggle>
      <div>
        <div class="jenjang-title">SMP, MTs, SMPIT.</div>
        <div class="jenjang-meta">Coming Soon · InsyaAllah</div>
      </div>
      <span class="jenjang-arrow">▼</span>
    </div>
    <div class="jenjang-body">
      <div class="coming-row">Sedang dalam persiapan — insyaAllah segera hadir.</div>
    </div>
  </div>

  <!-- SMA/MA -->
  <div class="jenjang-group">
    <div class="jenjang-header" data-toggle>
      <div>
        <div class="jenjang-title">SMA, MA, SMAIT</div>
        <div class="jenjang-meta">InsyaAllah</div>
      </div>
      <span class="jenjang-arrow">▼</span>
    </div>
    <div class="jenjang-body">
      <div class="coming-row">Dalam perencanaan — doakan agar Allah mudahkan, insyaAllah.</div>
    </div>
  </div>
</div>

<style>
  .section-desc { font-size: 14px; color: var(--text-sekunder); margin-bottom: 2rem; text-align: center; }
  .section-desc strong {
  color: var(--text-utama);
  font-weight: 600;
  }
  .jenjang-group { margin-bottom: 1rem; border: 1px solid var(--batas); border-radius: 12px; overflow: hidden; background: var(--putih); }
  .jenjang-header { display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.25rem; cursor: pointer; user-select: none; transition: background 0.2s; }
  .jenjang-header:hover { background: #f4faf7; }
  .jenjang-header.open { background: var(--hijau); color: #fff; }
  .jenjang-title { font-size: 14px; font-weight: 600; }
  .jenjang-meta { font-size: 12px; opacity: 0.65; margin-top: 2px; }
  .jenjang-header.open .jenjang-meta { color: rgba(255,255,255,0.7); }
  .jenjang-arrow { font-size: 12px; }
  .jenjang-body { max-height: 0; overflow: hidden; transition: max-height 0.35s ease; }
  .jenjang-body.open { max-height: 2000px; }

  .buku-list { padding: 0.75rem 1.25rem 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 0.75rem; }
  .buku-card {
  background: #f4faf7;
  border: 1px solid var(--batas);
  border-radius: 8px;
  padding: 0;          /* hapus padding dari card */
  display: flex;
  flex-direction: column;
  overflow: hidden;    /* tambah ini agar gambar ikut border-radius */
}

.buku-img-wrap {
  width: 100%;
  aspect-ratio: 3/4;  /* bisa ganti ke 4/3 untuk lebih lebar, atau 1/1 untuk kotak */
  overflow: hidden;
  background: #e0ede6;
  margin-bottom: 0;   /* hapus margin */
}

.buku-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}
.buku-card:hover .buku-img { transform: scale(1.04); }

/* teks di bawah gambar, beri padding di sini */
.buku-nama { 
  font-size: 12px; 
  font-weight: 600; 
  color: var(--text-utama); 
  margin-bottom: 0.2rem; 
  line-height: 1.4;
  padding: 0.75rem 0.75rem 0;  /* padding di teks, bukan card */
}
.buku-kelas { 
  font-size: 11px; 
  color: var(--text-sekunder);
  padding: 0 0.75rem;
}
.buku-badge { 
  display: inline-block; 
  margin: 0.4rem 0.75rem 0.75rem;  /* margin jadi padding bawah card */
  font-size: 10px; 
  font-weight: 600; 
  color: var(--hijau); 
  background: #d4eddf; 
  padding: 0.2rem 0.6rem; 
  border-radius: 4px; 
  align-self: flex-start; 
}

  .jenjang-actions { display: flex; gap: 0.75rem; padding: 1rem 1.25rem 1.25rem; flex-wrap: wrap; }
  .btn-katalog, .btn-pesan { font-size: 12px; font-weight: 600; padding: 0.55rem 1.1rem; border-radius: 8px; text-decoration: none; transition: all 0.2s; }
  .btn-katalog { background: var(--hijau); color: #fff; }
  .btn-katalog:hover { background: var(--hijau-mid); }
  .btn-pesan { background: var(--emas-muda); color: #7a5f00; border: 1px solid var(--emas); }
  .btn-pesan:hover { background: var(--emas); color: #fff; }
  .coming-row { padding: 1rem 1.25rem; font-size: 13px; color: var(--text-sekunder); font-style: italic; border-top: 1px solid var(--batas); }

  @media (max-width: 500px) {
    .buku-list { grid-template-columns: 1fr 1fr; }
    .jenjang-actions { flex-direction: column; }
    .btn-katalog, .btn-pesan { text-align: center; }
  }
</style>

<script>
  document.querySelectorAll('[data-toggle]').forEach(header => {
    header.addEventListener('click', () => {
      const body = header.nextElementSibling as HTMLElement;
      const isOpen = header.classList.contains('open');
      header.classList.toggle('open', !isOpen);
      body.classList.toggle('open', !isOpen);
      const arrow = header.querySelector('.jenjang-arrow') as HTMLElement;
      arrow.textContent = isOpen ? '▼' : '▲';
    });
  });
</script>