---
// src/layouts/Layout.astro
import { SEO } from "astro-seo";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <SEO
      title={title}
      titleTemplate="%s — Penerbit Luqmanulhakim"
      description={description ?? "Penerbit Luqmanulhakim - Buku & Aplikasi Pendidikan Islam"}
      canonical={Astro.url.href}
      openGraph={{
        basic: {
          title: title,
          type: "website",
          image: image ?? new URL("/og-default.jpg", Astro.site).toString(),
          url: Astro.url.href,
        },
        optional: {
          locale: "id_ID",
          siteName: "Penerbit Luqmanulhakim",
        },
      }}
    />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Penerbit Luqmanulhakim",
      "url": "https://luqmanulhakim.com",
      "logo": "https://luqmanulhakim.com/favicon.png",
      "description": "Penerbit buku dan aplikasi pendidikan Islam untuk sekolah dasar, terintegrasi nilai-nilai islami sesuai Kurikulum Merdeka.",
      "sameAs": [
        "https://luqmanulhakim.co.id",
        "https://luqmanulhakim.net"
      ]
    }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --hijau: #0d4a2a;
    --hijau-mid: #155c35;
    --hijau-muda: #E8F5EE;
    --emas: #c9a84c;
    --emas-muda: #FFF8E7;
    --text-utama: #1a2a1e;
    --text-sekunder: #4a5e52;
    --batas: #d4e6da;
    --putih: #ffffff;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Plus Jakarta Sans', sans-serif;
    color: var(--text-utama);
    background: #f9fbf9;
    line-height: 1.6;
  }
  a { text-decoration: none; color: inherit; }

  .section {
    padding: 2rem 1rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .section-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--emas);
    margin-bottom: 0.75rem;
    text-align: center;
  }
  .section-title {
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    font-weight: 600;
    color: var(--text-utama);
    margin-bottom: 0.5rem;
    text-align: center;
  }

  /* Divider otomatis antar section di dalam main */
  main > div + div {
    border-top: 1px solid var(--batas);
  }
</style>
